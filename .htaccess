ErrorDocument 404 /404.html

# Přesměrování ze starého webu (301 permanent)
Redirect 301 /vlaskovani/          /oboci
Redirect 301 /cenik/               /
Redirect 301 /oboci/               /oboci
Redirect 301 /salon/               /o-mne
Redirect 301 /kontakt/             /kontakt
Redirect 301 /kosmeticke-osetreni/ /kosmetika
Redirect 301 /o-mne/               /o-mne
Redirect 301 /kamaradka-do-kabelky/ /kurz-liceni

RewriteEngine On

# Přesměrování .html → čistá URL (301)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Interní přepis čisté URL → .html soubor
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)$ $1.html [L]
